# Postgres
POSTGRES_DB=artverse
POSTGRES_USER=artverse
POSTGRES_PASSWORD=change_me

# App
# If you keep the db service name db and the port 5432, this works:
DATABASE_URL=postgres://artverse:change_me@db:5432/artverse
SESSION_SECRET=change_me_long_random
# Email (Resend) — required for magic link signup
RESEND_API_KEY=re_xxxxx
# Sender address (must be verified in Resend dashboard)
RESEND_FROM_EMAIL=ArtVerse <gallery@idata.ro>
